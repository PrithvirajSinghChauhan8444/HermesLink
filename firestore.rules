rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Rules for the jobs collection
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      
      // Allow creation of pending jobs only with type validation and size checks (DoS prevention)
      allow create: if isAuthenticated() 
        && request.resource.data.state == 'PENDING'
        && request.resource.data.device_id is string
        && request.resource.data.device_id.size() < 100
        && request.resource.data.queue_id is string
        && request.resource.data.queue_id.size() < 100
        && request.resource.data.engine_config is map
        && request.resource.data.engine_config.url is string
        && request.resource.data.engine_config.url.size() < 2048;
      
      // Clients do not update or delete jobs directly (handled securely by the Agent)
      allow update, delete: if false;
    }

    // Rules for the queues collection
    match /queues/{queueId} {
      allow read: if isAuthenticated();
      
      // Allow queue management with strict parameter bounds
      allow create, update: if isAuthenticated()
        && request.resource.data.name is string
        && request.resource.data.name.size() < 100
        && request.resource.data.max_parallel_jobs is int
        && request.resource.data.max_parallel_jobs >= 1
        && request.resource.data.max_parallel_jobs <= 100
        && request.resource.data.max_threads_per_job is int
        && request.resource.data.max_threads_per_job >= 1
        && request.resource.data.max_threads_per_job <= 64
        && request.resource.data.priority is int
        && request.resource.data.priority >= 0
        && request.resource.data.enabled is bool;
      
      // Prevent deleting the default queue
      allow delete: if isAuthenticated() && queueId != 'default';
    }

    // Rules for the app_state collection
    match /app_state/{document} {
      // Administrative state is only managed via Admin SDK
      allow read, write: if false;
    }

    // Rules for the cookies collection
    match /cookies/{document} {
      // Allow authenticated clients to read the synced cookies
      allow read: if isAuthenticated();
      // Only Admin SDK (sync script) can write/update
      allow write: if false;
    }
  }
}
